# Generated from CONFIG_SCHEMA by scripts/generate-env-example.mjs.
# Copy this file to .env and adjust only the settings you need.
# Do not commit .env or put real credentials in this template.

# Embeddings

# Root directory containing knowledge base shelves.
# Default: $HOME/knowledge_bases
KNOWLEDGE_BASES_ROOT_DIR=

# Directory where FAISS index data is stored.
# Default: $KNOWLEDGE_BASES_ROOT_DIR/.faiss
FAISS_INDEX_PATH=

# enum configuration value.
# Default: flat
KB_INDEX_TYPE=flat

# HNSW graph connectivity when KB_INDEX_TYPE=hnsw.
# Default: 32
KB_HNSW_M=32

# HNSW build-time candidate list size when KB_INDEX_TYPE=hnsw.
# Default: 200
KB_HNSW_EF_CONSTRUCTION=200

# HNSW query-time candidate list size when KB_INDEX_TYPE=hnsw.
# Default: 100
KB_HNSW_EF_SEARCH=100

# HNSW random seed recorded in the index manifest.
# Default: 100
KB_HNSW_RANDOM_SEED=100

# Default embedding provider for retrieval and ingest.
# Default: huggingface
EMBEDDING_PROVIDER=huggingface

# Active model override; otherwise the active model sidecar or legacy provider env is used.
# Default: (unset)
KB_ACTIVE_MODEL=

# integer configuration value.
# Default: 256
KB_FAKE_DIM=256

# secret configuration value.
# Secret: leave empty until configured locally.
HUGGINGFACE_API_KEY=

# string configuration value.
# Default: BAAI/bge-small-en-v1.5
HUGGINGFACE_MODEL_NAME=BAAI/bge-small-en-v1.5

# string configuration value.
# Default: hf-inference
HUGGINGFACE_PROVIDER=hf-inference

# url configuration value.
# Default: https://router.huggingface.co/hf-inference/models/$HUGGINGFACE_MODEL_NAME/pipeline/feature-extraction
HUGGINGFACE_ENDPOINT_URL=

# url configuration value.
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# string configuration value.
# Default: dengcao/Qwen3-Embedding-0.6B:Q8_0
OLLAMA_MODEL=dengcao/Qwen3-Embedding-0.6B:Q8_0

# secret configuration value.
# Secret: leave empty until configured locally.
OPENAI_API_KEY=

# string configuration value.
# Default: text-embedding-3-small
OPENAI_MODEL_NAME=text-embedding-3-small

# Enables role-specific embedding task prefixes for model families that require separate document/query prefixes.
# Default: on
KB_EMBEDDING_TASK_PREFIXES=on

# Enables the process-shared open/half-open circuit breaker for embedding and LLM provider calls.
# Default: on
KB_PROVIDER_BREAKER=on

# Consecutive provider failures before the circuit opens.
# Default: 3
KB_PROVIDER_BREAKER_FAILURE_THRESHOLD=3

# Open-circuit cooldown before a single half-open recovery probe is allowed.
# Default: 30000
KB_PROVIDER_BREAKER_COOLDOWN_MS=30000

# Indexing and ingest

# integer configuration value.
# Default: 64; 16 when EMBEDDING_PROVIDER=ollama
INDEXING_BATCH_SIZE=

# integer configuration value.
# Default: 1
KB_INDEXING_CONCURRENCY=1

# integer configuration value.
# Default: 1000
KB_CHUNK_SIZE=1000

# integer configuration value.
# Default: 200; floor(KB_CHUNK_SIZE / 5) when KB_CHUNK_SIZE is customized
KB_CHUNK_OVERLAP=

# csv configuration value.
# Default: (empty)
INGEST_EXTRA_EXTENSIONS=

# csv configuration value.
# Default: (empty)
INGEST_EXCLUDE_PATHS=

# integer configuration value.
# Default: 104857600
KB_MAX_FILE_BYTES=104857600

# integer configuration value.
# Default: 16777216
KB_MAX_EXTRACTED_TEXT_BYTES=16777216

# enum configuration value.
# Default: skip
KB_LARGE_FILE_POLICY=skip

# duration configuration value.
# Default: 0
KB_REFRESH_QUIESCE_MS=0

# boolean configuration value.
# Default: on
KB_INGEST_ENABLED=on

# boolean configuration value.
# Default: off
KB_INGEST_SECRET_SCAN=off

# csv configuration value.
# Default: (empty)
KB_SECRET_SCAN_BYPASS_KBS=

# Caching

# Enables the query embedding cache.
# Default: on
KB_QUERY_CACHE=on

# integer configuration value.
# Default: 256
KB_QUERY_CACHE_LRU_MAX=256

# number configuration value.
# Default: 64
KB_QUERY_CACHE_DISK_MAX_MB=64

# LLM and contextual retrieval

# Enables LLM contextual prefaces during ingest.
# Default: off
KB_CONTEXTUAL_RETRIEVAL=off

# csv configuration value.
# Default: (empty)
KB_RETRIEVAL_VIEWS=

# integer configuration value.
# Default: 150
KB_CONTEXTUAL_MAX_TOKENS=150

# integer configuration value.
# Default: 10
KB_CONTEXTUAL_CONCURRENCY=10

# url configuration value.
# Default: (unset)
KB_LLM_ENDPOINT=

# string configuration value.
# Default: (unset)
KB_LLM_MODEL=

# enum configuration value.
# Default: local
KB_LLM_PROVIDER=local

# secret configuration value.
# Secret: leave empty until configured locally.
KB_OPENROUTER_API_KEY=

# secret configuration value.
# Secret: leave empty until configured locally.
OPENROUTER_API_KEY=

# string configuration value.
# Default: knowledge-base-mcp
KB_LLM_APP_TITLE=knowledge-base-mcp

# string configuration value.
# Default: (unset)
KB_LLM_HTTP_REFERER=

# boolean configuration value.
# Default: off
KB_LLM_FAKE=off

# path configuration value.
# Default: (unset)
KB_LLM_FAKE_RULES=

# OpenAI-compatible endpoint used only by LLM query decomposition; falls back to KB_LLM_ENDPOINT when unset.
# Default: (unset)
KB_DECOMPOSE_LLM_ENDPOINT=

# Model override used only by LLM query decomposition; falls back to KB_LLM_MODEL when unset.
# Default: (unset)
KB_DECOMPOSE_LLM_MODEL=

# Enables the process LRU and persistent disk cache for query-decomposition results.
# Default: off
KB_DECOMPOSE_CACHE_ENABLED=off

# Maximum query-decomposition entries retained in the process LRU; 0 disables the memory tier.
# Default: 256
KB_DECOMPOSE_CACHE_LRU_MAX=256

# Maximum bytes retained under $FAISS_INDEX_PATH/cache/query-decompositions.
# Default: 67108864
KB_DECOMPOSE_CACHE_DISK_MAX_BYTES=67108864

# path configuration value.
# Default: $XDG_CONFIG_HOME/kb/llm or ~/.config/kb/llm
KB_LLM_CONFIG_DIR=

# path configuration value.
# Default: $XDG_STATE_HOME/kb/llm or ~/.local/state/kb/llm
KB_LLM_STATE_DIR=

# path configuration value.
# Default: $XDG_CONFIG_HOME/systemd/user or ~/.config/systemd/user
KB_LLM_SYSTEMD_USER_DIR=

# Relevance gate

# Enables recall-negative relevance gating by default.
# Default: off
KB_RELEVANCE_GATE=off

# Allows dense and hybrid retrieval to degrade to lexical-only results during transient provider errors.
# Default: off
KB_DENSE_DEGRADE_ON_PROVIDER_ERROR=off

# boolean configuration value.
# Default: off
KB_GATE_EMPTY_VERDICT=off

# number configuration value.
# Default: 0.95
KB_GATE_SCORE_FLOOR=0.95

# integer configuration value.
# Default: 10
KB_GATE_JUDGE_INPUT=10

# duration configuration value.
# Default: 8000
KB_GATE_LLM_TIMEOUT_MS=8000

# integer configuration value.
# Default: 8
KB_GATE_MIN_TASK_TOKENS=8

# url configuration value.
# Default: (unset)
KB_GATE_LLM_ENDPOINT=

# string configuration value.
# Default: (unset)
KB_GATE_LLM_MODEL=

# enum configuration value.
# Default: warn
KB_GATE_TASK_CONTEXT_MODE=warn

# integer configuration value.
# Default: 600
KB_GATE_TASK_CONTEXT_ARGV_MAX=600

# Reranking

# Enables optional cross-encoder reranking.
# Default: off
KB_RERANK=off

# string configuration value.
# Default: Xenova/ms-marco-MiniLM-L-6-v2
KB_RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

# integer configuration value.
# Default: 40
KB_RERANK_TOP_N=40

# Sub-batches cross-encoder inference to bound peak memory; 0 = single call (default).
# Default: 0
KB_RERANK_BATCH_SIZE=0

# csv configuration value.
# Default: (unset)
KB_RERANK_SKIP_DOMAINS=

# Enables the persistent disk-tiered rerank-score cache.
# Default: off
KB_RERANK_CACHE=off

# Disk-size cap in bytes for the persistent rerank-score cache.
# Default: 67108864
KB_RERANK_CACHE_DISK_MAX_BYTES=67108864

# Optional @huggingface/transformers device override for cross-encoder reranking, such as cuda.
# Default: (unset)
KB_RERANK_DEVICE=

# Optional @huggingface/transformers dtype override for cross-encoder reranking, such as fp32.
# Default: (unset)
KB_RERANK_DTYPE=

# Retrieval safety and display

# enum configuration value.
# Default: tag
KB_INJECTION_GUARD=tag

# csv configuration value.
# Default: (unset)
KB_INJECTION_GUARD_BYPASS_KBS=

# string configuration value.
# Default: (unset)
KB_INJECTION_GUARD_WRAP_OPEN=

# string configuration value.
# Default: (unset)
KB_INJECTION_GUARD_WRAP_CLOSE=

# Enables retrieval-time injection signal scanning; set exactly to off to omit injection_signals.
# Default: on
KB_SHIELD=on

# enum configuration value.
# Default: none
KB_EDITOR_URI=none

# boolean configuration value.
# Default: false
FRONTMATTER_EXTRAS_WIRE_VISIBLE=false

# Logging and metrics

# enum configuration value.
# Default: both
KB_LOG_FORMAT=both

# enum configuration value.
# Default: info
LOG_LEVEL=info

# path configuration value.
# Default: (unset)
LOG_FILE=

# Enables size-based LOG_FILE rotation when set to a positive byte cap.
# Default: (unset)
KB_LOG_MAX_BYTES=

# Retained rotated LOG_FILE generations when KB_LOG_MAX_BYTES enables rotation.
# Default: 5
KB_LOG_MAX_FILES=5

# boolean configuration value.
# Default: off
KB_LOG_VERBOSE=off

# duration configuration value.
# Default: (unset)
KB_SLOW_QUERY_MS=

# boolean configuration value.
# Default: off
KB_METRICS_EXPORT=off

# duration configuration value.
# Default: 50
KB_FLAT_SEARCH_P95_ADVISORY_MS=50

# path configuration value.
# Default: (unset)
KB_MUTATION_AUDIT_LOG=

# integer configuration value.
# Default: (unset)
KB_AGE_BUDGET_HOURS=

# Daemon and MCP transport

# url configuration value.
# Default: (unset)
KB_DAEMON_URL=

# path configuration value.
# Default: (unset)
KB_DAEMON_SOCKET=

# string configuration value.
# Default: 127.0.0.1
KB_DAEMON_HOST=127.0.0.1

# integer configuration value.
# Default: 17799
KB_DAEMON_PORT=17799

# Timeout in milliseconds for daemon command requests.
# Default: 1500
KB_DAEMON_CLIENT_TIMEOUT_MS=1500

# Timeout in milliseconds for daemon health requests, capped by any outer autostart deadline.
# Default: 500
KB_DAEMON_HEALTH_TIMEOUT_MS=500

# Bounded wait (ms) for in-flight kb serve requests to finish on SIGINT/SIGTERM before the daemon force-exits. 0 stops immediately.
# Default: 5000
KB_DAEMON_DRAIN_TIMEOUT_MS=5000

# boolean configuration value.
# Default: off
KB_DAEMON_AUTOSTART=off

# boolean configuration value.
# Default: off
KB_DAEMON_PREWARM=off

# MCP server transport.
# Default: stdio
MCP_TRANSPORT=stdio

# integer configuration value.
# Default: 8765
MCP_PORT=8765

# string configuration value.
# Default: 127.0.0.1
MCP_BIND_ADDR=127.0.0.1

# Bearer token required for HTTP/SSE transports.
# Secret: leave empty until configured locally.
MCP_AUTH_TOKEN=

# Path to a file containing the bearer token for HTTP/SSE transports; takes precedence over MCP_AUTH_TOKEN.
# Default: (unset)
MCP_AUTH_TOKEN_FILE=

# csv configuration value.
# Default: (unset)
MCP_ALLOWED_ORIGINS=

# Extra Host-header values accepted by the HTTP/SSE transports for DNS-rebinding protection. Loopback aliases derived from MCP_BIND_ADDR/MCP_PORT are always allowed; set to * to disable Host validation for reverse-proxy setups.
# Default: (unset)
MCP_ALLOWED_HOSTS=

# integer configuration value.
# Default: 5
MCP_AUTH_BACKOFF_THRESHOLD=5

# duration configuration value.
# Default: 30000
MCP_AUTH_BACKOFF_MS=30000

# integer configuration value.
# Default: 1024
MCP_AUTH_BACKOFF_MAX_ENTRIES=1024

# Maximum query string length accepted by MCP retrieval and ask tools.
# Default: 8192
KB_MAX_QUERY_CHARS=8192

# Maximum number of filter items accepted by MCP retrieval and diff tools.
# Default: 64
KB_MAX_FILTER_ITEMS=64

# Maximum path_glob length accepted by MCP retrieval tools.
# Default: 1024
KB_MAX_GLOB_CHARS=1024

# Maximum wildcard count accepted in MCP retrieval path_glob filters.
# Default: 64
KB_MAX_GLOB_WILDCARDS=64

# Index watching

# path configuration value.
# Default: $KNOWLEDGE_BASES_ROOT_DIR/.reindex-trigger
REINDEX_TRIGGER_PATH=

# duration configuration value.
# Default: 5000
REINDEX_TRIGGER_POLL_MS=5000

# boolean configuration value.
# Default: off
KB_FS_WATCH=off

# duration configuration value.
# Default: 250
KB_FS_WATCH_DEBOUNCE_MS=250

# integer configuration value.
# Default: 2
KB_INDEX_VERSION_RETENTION=2

# Free-space safety margin retained after write-heavy reindex and ingest estimates.
# Default: 536870912
KB_MIN_FREE_DISK_BYTES=536870912

# MCP descriptions and ask

# string configuration value.
# Default: Retrieves similar chunks from the knowledge base based on a query. Optionally, if a knowledge base is specified, only that one is searched; otherwise, all available knowledge bases are considered. By default, at most 10 documents are returned. Dense retrieval limits results to a similarity score of 2 by default; a different threshold can optionally be provided. Hybrid retrieval does not apply this threshold because both legs are over-fetched for fusion.
RETRIEVE_KNOWLEDGE_DESCRIPTION="Retrieves similar chunks from the knowledge base based on a query. Optionally, if a knowledge base is specified, only that one is searched; otherwise, all available knowledge bases are considered. By default, at most 10 documents are returned. Dense retrieval limits results to a similarity score of 2 by default; a different threshold can optionally be provided. Hybrid retrieval does not apply this threshold because both legs are over-fetched for fusion."

# string configuration value.
# Default: Answers a question from retrieved knowledge-base context using the configured local OpenAI-compatible LLM endpoint. Returns a structured payload with answer, citations, context-packing diagnostics, abstention_reason, LLM provenance, retrieval model, and optional timing. Use retrieve_knowledge when you only need raw chunks.
ASK_KNOWLEDGE_DESCRIPTION="Answers a question from retrieved knowledge-base context using the configured local OpenAI-compatible LLM endpoint. Returns a structured payload with answer, citations, context-packing diagnostics, abstention_reason, LLM provenance, retrieval model, and optional timing. Use retrieve_knowledge when you only need raw chunks."

# string configuration value.
# Default: Lists the available knowledge bases.
LIST_KNOWLEDGE_BASES_DESCRIPTION="Lists the available knowledge bases."

# string configuration value.
# Default: Lists the embedding models registered for retrieval. Returns an array of {model_id, provider, model_name, active}. Use the model_id as the optional `model_name` argument to retrieve_knowledge to query a specific model instead of the active default.
LIST_MODELS_DESCRIPTION="Lists the embedding models registered for retrieval. Returns an array of {model_id, provider, model_name, active}. Use the model_id as the optional `model_name` argument to retrieve_knowledge to query a specific model instead of the active default."

# string configuration value.
# Default: Reports observability stats for the knowledge base index: per-KB file_count, chunk_count, total_bytes_indexed and last_updated_at; the active embedding provider/model/dim; the on-disk index_path; server version/commit/uptime; process-lifetime chat-completion calls with bounded provider/model attribution, attempts/retries, cache outcomes, and answer impact; answer-cache counters; and HTTP/SSE transport counters when a remote transport is active. Pass `knowledge_base_name` to scope to a single KB; omit it to get an entry per registered KB.
KB_STATS_DESCRIPTION="Reports observability stats for the knowledge base index: per-KB file_count, chunk_count, total_bytes_indexed and last_updated_at; the active embedding provider/model/dim; the on-disk index_path; server version/commit/uptime; process-lifetime chat-completion calls with bounded provider/model attribution, attempts/retries, cache outcomes, and answer impact; answer-cache counters; and HTTP/SSE transport counters when a remote transport is active. Pass `knowledge_base_name` to scope to a single KB; omit it to get an entry per registered KB."

# Default kb search snippet mode; accepts off aliases, on aliases, or a positive line count.
# Default: (unset)
KB_SEARCH_SNIPPET=

# Advertises the MCP prompts capability with read-only KB prompt templates.
# Default: off
KB_MCP_PROMPTS=off

# Scrub secrets (via redactSecrets) from the assembled kb ask prompt before it is sent to a remote LLM. Defaults on for remote providers; set explicitly to scrub (or skip) on the local path.
# Default: on when KB_LLM_PROVIDER=openrouter (remote); off for local
KB_ASK_REDACT_OUTBOUND=

# Enables the opt-in kb ask / ask_knowledge answer cache keyed by query + retrieved-context fingerprint + embedding model + LLM profile. Invalidates implicitly when the retrieved context changes.
# Default: off
KB_ASK_CACHE=off

# Disk-size cap (MiB) for the answer cache; oldest entries are evicted first on write.
# Default: 64
KB_ASK_CACHE_DISK_MAX_MB=64

# OpenTelemetry

# Opt into OpenTelemetry (OTLP) distributed trace export for the retrieve/ask pipeline. Off by default and zero-cost when disabled; when on, the optional @opentelemetry/* packages are lazily loaded and spans are exported via OTLP/HTTP. Honors the standard OTEL_EXPORTER_OTLP_ENDPOINT and OTEL_SERVICE_NAME env vars.
# Default: off
KB_OTEL_TRACES=off

# Standard OpenTelemetry OTLP collector endpoint used for trace export when KB_OTEL_TRACES is enabled (e.g. http://localhost:4318).
# Default: (unset)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Standard OpenTelemetry service.name attached to exported traces when KB_OTEL_TRACES is enabled.
# Default: knowledge-base-mcp-server
OTEL_SERVICE_NAME=

# Other

# Per-call deadline for network embedding-provider calls; on expiry the call fails with PROVIDER_TIMEOUT and the circuit breaker records it.
# Default: 120000
KB_EMBED_TIMEOUT_MS=120000
